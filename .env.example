# SampleSecure Environment Configuration

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Pinata IPFS Configuration
VITE_PINATA_API_KEY=your_pinata_api_key
VITE_PINATA_SECRET_API_KEY=your_pinata_secret_key
VITE_PINATA_JWT=your_pinata_jwt_token

# OpenAI Configuration
VITE_OPENAI_API_KEY=your_openai_api_key

# Privy Configuration
VITE_PRIVY_APP_ID=your_privy_app_id

# Base Network Configuration
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_ALCHEMY_API_KEY=your_alchemy_api_key

# Application Configuration
VITE_APP_ENV=development
VITE_API_BASE_URL=https://api.samplesecure.com
VITE_PAYMENT_BASE_URL=https://payments.vistara.dev

# Feature Flags
VITE_ENABLE_AI_CATEGORIZATION=true
VITE_ENABLE_IPFS_STORAGE=true
VITE_ENABLE_ON_CHAIN_FEATURES=false
